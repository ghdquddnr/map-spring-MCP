{
  "name": "@ghdquddnr/mapspring-mcp",
  "version": "1.0.0",
  "description": "MapSpring MCP server for database exploration and Spring integration",
  "main": "dist/index.js",
  "bin": {
    "mapspring-mcp": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "watch": "tsc -w",
    "test": "jest",
    "prepare": "npm run build",
    "build:mcpb": "npm run build && npm prune --production && mcpb pack && npm install"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.4.1",
    "dotenv": "^16.4.5",
    "mysql2": "^3.9.2",
    "oracledb": "^6.3.0",
    "pg": "^8.11.3",
    "mssql": "^10.0.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@types/pg": "^8.11.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
